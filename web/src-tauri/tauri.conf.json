{
  "productName": "conductor",
  "version": "0.1.0",
  "identifier": "com.conductor.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../dist/webui/static"
  },
  "app": {
    "security": { "csp": null },
    "windows": [{
      "title": "Conductor — Multi-Agent Terminal Workbench",
      "width": 1400,
      "height": 900,
      "minWidth": 800,
      "minHeight": 500,
      "resizable": true,
      "decorations": true,
      "center": true
    }]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
  }
}
